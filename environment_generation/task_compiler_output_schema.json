{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "selector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "semantic_type", "body_type", "shape", "tag"],
      "properties": {
        "id": {"type": ["string", "null"]},
        "semantic_type": {"type": ["string", "null"]},
        "body_type": {"type": ["string", "null"]},
        "shape": {"type": ["string", "null"]},
        "tag": {"type": ["string", "null"]}
      }
    },
    "predicate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "subject",
        "subject_quantifier",
        "target",
        "relation",
        "metric",
        "space",
        "axis",
        "component",
        "state",
        "event",
        "reason",
        "mechanism_id",
        "margin",
        "min_distance",
        "max_distance",
        "min_value",
        "max_value",
        "max_linear_speed",
        "max_angular_speed",
        "min_progress"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "overlap",
            "relation",
            "displacement",
            "axis_delta",
            "contact",
            "axis_value",
            "speed",
            "settled",
            "mechanism_state",
            "jump_count",
            "step_count",
            "reset_count",
            "reset_event",
            "terminal_event",
            "in_bounds",
            "grounded"
          ]
        },
        "subject": {"anyOf": [{"$ref": "#/$defs/selector"}, {"type": "null"}]},
        "subject_quantifier": {"type": ["string", "null"], "enum": ["any", "all", null]},
        "target": {"anyOf": [{"$ref": "#/$defs/selector"}, {"type": "null"}]},
        "relation": {
          "type": ["string", "null"],
          "enum": ["left_of", "right_of", "in_front_of", "behind", "above", "below", "near", "far_from", "inside", "on_surface", null]
        },
        "metric": {"type": ["string", "null"], "enum": ["maximum", "minimum", "final", null]},
        "space": {"type": ["string", "null"], "enum": ["xy", "xyz", null]},
        "axis": {"type": ["string", "null"], "enum": ["x", "y", "z", null]},
        "component": {"type": ["string", "null"], "enum": ["linear", "angular", null]},
        "state": {"type": ["string", "null"], "enum": ["active", "open", null]},
        "event": {"type": ["string", "null"], "enum": ["goal", "hazard", "out_of_bounds", null]},
        "reason": {"type": ["string", "null"]},
        "mechanism_id": {"type": ["string", "null"]},
        "margin": {"type": ["number", "null"]},
        "min_distance": {"type": ["number", "null"]},
        "max_distance": {"type": ["number", "null"]},
        "min_value": {"type": ["number", "null"]},
        "max_value": {"type": ["number", "null"]},
        "max_linear_speed": {"type": ["number", "null"]},
        "max_angular_speed": {"type": ["number", "null"]},
        "min_progress": {"type": ["number", "null"]}
      }
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["task_id", "summary", "max_steps", "tests"],
  "properties": {
    "task_id": {"type": "string", "minLength": 1, "maxLength": 80},
    "summary": {"type": "string", "minLength": 1, "maxLength": 1200},
    "max_steps": {"type": "integer", "minimum": 60, "maximum": 20000},
    "tests": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "description", "mode", "conditions", "ordered_condition_ids"],
        "properties": {
          "id": {"type": "string", "minLength": 1, "maxLength": 80},
          "description": {"type": "string", "minLength": 1, "maxLength": 600},
          "mode": {"type": "string", "enum": ["all", "any"]},
          "ordered_condition_ids": {
            "type": "array",
            "maxItems": 16,
            "items": {"type": "string", "minLength": 1, "maxLength": 80}
          },
          "conditions": {
            "type": "array",
            "minItems": 1,
            "maxItems": 16,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "description", "temporal", "frames", "min_count", "max_count", "predicate"],
              "properties": {
                "id": {"type": "string", "minLength": 1, "maxLength": 80},
                "description": {"type": "string", "minLength": 1, "maxLength": 600},
                "temporal": {
                  "type": "string",
                  "enum": ["eventually", "at_end", "always", "never", "sustained", "count"]
                },
                "frames": {"type": ["integer", "null"], "minimum": 1, "maximum": 10000},
                "min_count": {"type": ["integer", "null"], "minimum": 0, "maximum": 20000},
                "max_count": {"type": ["integer", "null"], "minimum": 0, "maximum": 20000},
                "predicate": {"$ref": "#/$defs/predicate"}
              }
            }
          }
        }
      }
    }
  }
}
