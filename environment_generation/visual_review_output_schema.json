{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "summary", "checks"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["passed", "failed"]
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1200
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "category", "passed", "severity", "message", "evidence", "repair_hint"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          },
          "category": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          },
          "passed": {
            "type": "boolean"
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "advisory"]
          },
          "message": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1200
          },
          "evidence": {
            "type": "array",
            "maxItems": 8,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["view_id", "phase", "observation"],
              "properties": {
                "view_id": {
                  "type": "string",
                  "enum": ["primary", "reverse", "layout"]
                },
                "phase": {
                  "type": "string",
                  "enum": ["before", "after"]
                },
                "observation": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 600
                }
              }
            }
          },
          "repair_hint": {
            "type": "string",
            "maxLength": 1200
          }
        }
      }
    }
  }
}
